{
  "name": "ClassEnrollment",
  "type": "object",
  "properties": {
    "class_id": {
      "type": "string",
      "description": "ID of the class"
    },
    "student_id": {
      "type": "string",
      "description": "ID of the student"
    },
    "student_name": {
      "type": "string",
      "description": "Name of the student"
    },
    "student_email": {
      "type": "string",
      "description": "Email of the student"
    },
    "enrolled_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the student enrolled"
    }
  },
  "required": [
    "class_id",
    "student_id",
    "student_name",
    "student_email"
  ],
  "rls": {
    "read": {
      "$or": [
        {
          "user_condition": {
            "data.app_role": "student"
          }
        },
        {
          "user_condition": {
            "data.app_role": "teacher"
          }
        }
      ]
    },
    "write": {
      "$or": [
        {
          "user_condition": {
            "data.app_role": "student"
          }
        },
        {
          "user_condition": {
            "data.app_role": "teacher"
          }
        }
      ]
    }
  }
}