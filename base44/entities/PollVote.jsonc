{
  "name": "PollVote",
  "type": "object",
  "properties": {
    "poll_id": {
      "type": "string"
    },
    "selected_option": {
      "type": "string"
    },
    "student_id": {
      "type": "string"
    }
  },
  "required": [
    "poll_id",
    "selected_option",
    "student_id"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "user_condition": {
            "data.app_role": "teacher"
          }
        },
        {
          "user_condition": {
            "data.app_role": "student"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "data.app_role": "teacher"
          }
        },
        {
          "user_condition": {
            "data.app_role": "student"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "data.app_role": "teacher"
          }
        },
        {
          "$and": [
            {
              "user_condition": {
                "data.app_role": "student"
              }
            },
            {
              "data.student_id": "{{user.id}}"
            }
          ]
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "data.app_role": "teacher"
          }
        },
        {
          "$and": [
            {
              "user_condition": {
                "data.app_role": "student"
              }
            },
            {
              "data.student_id": "{{user.id}}"
            }
          ]
        }
      ]
    }
  }
}